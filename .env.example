# Example environment for Docker Compose.
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# Required in production — generate with: openssl rand -hex 32
JWT_SECRET=

# Comma-separated list of allowed browser origins (CORS).
CORS_ORIGINS=http://localhost:3000,http://localhost

# Set to "true" ONLY when serving over HTTPS (cookies become Secure).
COOKIE_SECURE=false

# Platform admin credentials (hardcoded emails, set passwords via env)
# System Admin: wamuyuwamundia@gmail.com
# Business Admin: brightilunga6@gmail.com
SYSTEM_ADMIN_EMAIL=wamuyuwamundia@gmail.com
SYSTEM_ADMIN_PASSWORD=
BUSINESS_ADMIN_EMAIL=brightilunga6@gmail.com
BUSINESS_ADMIN_PASSWORD=
