# Example environment for Docker Compose.
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# Required in production — generate with: openssl rand -hex 32
JWT_SECRET=

# Comma-separated list of allowed browser origins (CORS).
CORS_ORIGINS=http://localhost:3000,http://localhost

# Set to "true" ONLY when serving over HTTPS (cookies become Secure).
COOKIE_SECURE=false

# Optional: set these to choose the two platform admin passwords on first seed.
# If left empty, strong random passwords are generated and printed to the server log.
SYSTEM_ADMIN_PASSWORD=
BUSINESS_ADMIN_PASSWORD=
